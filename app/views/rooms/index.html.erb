<%# パンくずリスト %>

<%# title %>
<h2 class="text-2xl font-bold mb-4">部屋一覧</h2>

<%# 検索フォーム %>

<%# 新規作成（モーダルで name を入力して作成 → エディターへ） %>
<%# バリデーションエラー時（create の再描画）はモーダルを開いた状態で表示する %>
<%# update 失敗時の再描画では @room が既存部屋になるため、新規作成用と区別する %>
<% new_room = @room.new_record? ? @room : Room.new %>
<div data-controller="modal" data-modal-open-value="<%= new_room.errors.any? %>" class="mb-4">
  <button type="button" class="btn btn-primary" data-action="modal#open">新規作成</button>

  <dialog class="modal" data-modal-target="dialog">
    <div class="modal-box">
      <button type="button" class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="modal#close" aria-label="閉じる">✕</button>
      <h3 class="text-lg font-bold mb-4">部屋の新規作成</h3>
      <%= render "form", room: new_room %>
    </div>
    <%# 背景クリックで閉じる（dialog の標準機能） %>
    <form method="dialog" class="modal-backdrop"><button>閉じる</button></form>
  </dialog>
</div>

<%# テーブル : ヘッダーは以下に記述 %>
<div class="overflow-x-auto bg-base-100 rounded-box shadow-sm">
  <table class="table">
    <thead>
      <tr>
        <th>部屋名</th>
        <th class="w-0"></th>
      </tr>
    </thead>
    <tbody>
      <% @rooms.each do |room| %>
        <%# update 失敗時はエラーを保持した @room をこの行のフォームに使い、モーダルを開いた状態にする %>
        <% edit_room = (@room.persisted? && @room.id == room.id) ? @room : room %>
        <tr>
          <td><%= link_to room.name, room_path(room), class: "link link-hover" %></td>
          <td>
            <div class="flex justify-end gap-1">
              <%# 部屋名の編集（新規作成と同じフォームをモーダルで流用） %>
              <div data-controller="modal" data-modal-open-value="<%= edit_room.errors.any? %>">
                <button type="button" class="btn btn-ghost btn-sm btn-square text-info" data-action="modal#open" aria-label="部屋名を編集">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="w-6 h-6 fill-current"><!--!Font Awesome Free v7.3.1 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M535.6 85.7C513.7 63.8 478.3 63.8 456.4 85.7L432 110.1L529.9 208L554.3 183.6C576.2 161.7 576.2 126.3 554.3 104.4L535.6 85.7zM236.4 305.7C230.3 311.8 225.6 319.3 222.9 327.6L193.3 416.4C190.4 425 192.7 434.5 199.1 441C205.5 447.5 215 449.7 223.7 446.8L312.5 417.2C320.7 414.5 328.2 409.8 334.4 403.7L496 241.9L398.1 144L236.4 305.7zM160 128C107 128 64 171 64 224L64 480C64 533 107 576 160 576L416 576C469 576 512 533 512 480L512 384C512 366.3 497.7 352 480 352C462.3 352 448 366.3 448 384L448 480C448 497.7 433.7 512 416 512L160 512C142.3 512 128 497.7 128 480L128 224C128 206.3 142.3 192 160 192L256 192C273.7 192 288 177.7 288 160C288 142.3 273.7 128 256 128L160 128z"/></svg>
                </button>

                <dialog class="modal" data-modal-target="dialog">
                  <div class="modal-box">
                    <button type="button" class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="modal#close" aria-label="閉じる">✕</button>
                    <h3 class="text-lg font-bold mb-4">部屋名の編集</h3>
                    <%= render "form", room: edit_room %>
                  </div>
                  <form method="dialog" class="modal-backdrop"><button>閉じる</button></form>
                </dialog>
              </div>

              <%# 部屋の削除（モーダルで確認してから削除） %>
              <div data-controller="modal">
                <button type="button" class="btn btn-ghost btn-sm btn-square text-error" data-action="modal#open" aria-label="部屋を削除">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="w-6 h-6 fill-current"><!--!Font Awesome Free v7.3.1 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M232.7 69.9C237.1 56.8 249.3 48 263.1 48L377 48C390.8 48 403 56.8 407.4 69.9L416 96L512 96C529.7 96 544 110.3 544 128C544 145.7 529.7 160 512 160L128 160C110.3 160 96 145.7 96 128C96 110.3 110.3 96 128 96L224 96L232.7 69.9zM128 208L512 208L512 512C512 547.3 483.3 576 448 576L192 576C156.7 576 128 547.3 128 512L128 208zM216 272C202.7 272 192 282.7 192 296L192 488C192 501.3 202.7 512 216 512C229.3 512 240 501.3 240 488L240 296C240 282.7 229.3 272 216 272zM320 272C306.7 272 296 282.7 296 296L296 488C296 501.3 306.7 512 320 512C333.3 512 344 501.3 344 488L344 296C344 282.7 333.3 272 320 272zM424 272C410.7 272 400 282.7 400 296L400 488C400 501.3 410.7 512 424 512C437.3 512 448 501.3 448 488L448 296C448 282.7 437.3 272 424 272z"/></svg>
                </button>

                <dialog class="modal" data-modal-target="dialog">
                  <div class="modal-box">
                    <h3 class="text-lg font-bold mb-4">部屋の削除</h3>
                    <p class="mb-4">「<%= room.name %>」を削除します。よろしいですか？<br>部屋の中の家具も一緒に削除されます。</p>
                    <div class="flex justify-center gap-2">
                      <button type="button" class="btn" data-action="modal#close">キャンセル</button>
                      <%= button_to "削除する", room_path(room), method: :delete, class: "btn btn-error" %>
                    </div>
                  </div>
                  <form method="dialog" class="modal-backdrop"><button>閉じる</button></form>
                </dialog>
              </div>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
