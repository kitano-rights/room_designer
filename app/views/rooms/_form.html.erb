<%# 部屋の作成フォーム（モーダル / new ページ共用） %>
<%= form_with model: room do |f| %>
  <% if room.errors.any? %>
    <ul class="text-error text-sm list-disc list-inside mb-3">
      <% room.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>

  <div class="mb-4">
    <%= f.label :name, "部屋名", class: "label mb-1" %>
    <%= f.text_field :name, autofocus: true, class: "input w-full" %>
  </div>

  <div class="text-right">
    <%= f.submit "作成してエディターへ", class: "btn btn-primary" %>
  </div>
<% end %>
